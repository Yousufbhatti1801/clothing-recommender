# App
DEBUG=false
APP_NAME=AI Clothing Recommender

# Security — CHANGE ALL OF THESE IN PRODUCTION
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change-me-in-production

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=["https://yourapp.com","https://admin.yourapp.com"]

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=20

# PostgreSQL (When using docker-compose, use the 'db' service hostname instead of 'localhost')
DB_URL=postgresql+asyncpg://postgres:postgres@db:5432/clothing_db

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=clothing-embeddings

# CLIP
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_DEVICE=cpu  # Set to "cuda" on GPU instances

# YOLOv8
YOLO_MODEL_PATH=ml/models/yolov8_fashion.pt
YOLO_CONFIDENCE_THRESHOLD=0.4

# Search
PINECONE_TOP_K=20

# Locality boost
LOCALITY_BOOST=0.15
LOCALITY_RADIUS_KM=50.0

# Observability
# Get DSN from https://sentry.io (leave blank to disable)
SENTRY_DSN=

# SSRF Protection — comma-separated list of allowed image download hosts.
# Leave empty in development (all hosts allowed).
# Example: ALLOWED_IMAGE_HOSTS=cdn.mystore.com,images.mystore.com
ALLOWED_IMAGE_HOSTS=images.unsplash.com
