# App
DEBUG=false

# PostgreSQL
DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clothing_db

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=clothing-embeddings

# CLIP
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
CLIP_DEVICE=cpu

# YOLOv8
YOLO_MODEL_PATH=ml/models/yolov8_fashion.pt
YOLO_CONFIDENCE_THRESHOLD=0.4

# Search
PINECONE_TOP_K=20

# Locality boost
LOCALITY_BOOST=0.15
LOCALITY_RADIUS_KM=50.0
